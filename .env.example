# Universal AI Proxy Configuration

# Server Configuration
PORT=3000
HOST=localhost
NODE_ENV=development
LOG_LEVEL=info

# Google OAuth Credentials (for platforms using Google auth)
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Your Google Account Credentials
# Used for authenticating with AI platforms
GOOGLE_EMAIL=your-email@gmail.com
GOOGLE_PASSWORD=your-app-password

# Session Encryption
SESSION_SECRET=your-secret-key-for-encryption

# API Keys (optional - for direct API access if needed)
ANTHROPIC_API_KEY=sk-ant-
OPENAI_API_KEY=sk-

# Proxy Settings (if behind a corporate proxy)
HTTP_PROXY=
HTTPS_PROXY=

# Browser Configuration
BROWSER_HEADLESS=false
BROWSER_TIMEOUT=30000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
